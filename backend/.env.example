# Backend Environment Variables
# Copy this file to .env and update the values

# CORS origins (comma-separated list of allowed frontend URLs)
CORS_ORIGINS_STR=https://your-frontend.vercel.app

# Thread pool configuration
MAX_WORKERS=2

# Job expiration (hours)
JOB_EXPIRY_HOURS=1

# SSL verification bypass (only set to true for development with corporate proxies)
DISABLE_SSL_VERIFY=false
